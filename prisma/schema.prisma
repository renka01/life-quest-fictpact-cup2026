generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Akan di-hash dengan bcrypt
  name      String?
  
  // 🔥 Di sinilah kita menyimpan seluruh state Zustand kamu (stats, inventory, tasks)
  gameState Json?    

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}